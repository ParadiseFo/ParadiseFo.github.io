# 复制为 .env 后配置。推荐用 dotenvx 仅加密 DATABASE_URL：
#   npx dotenvx encrypt -f .env -k DATABASE_URL
# 并保管 .env.keys（勿提交）。详见 docs/ENV-DOTENVX.md

# MySQL（示例）
# DATABASE_URL="mysql://USER:PASSWORD@127.0.0.1:3306/techblog"

JWT_SECRET="replace-with-a-long-random-secret"

PORT=4000
HOST=0.0.0.0

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme-please-8chars-min
