---
import '../../styles/global.css';
import '../../styles/admin.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
/* 线上站点为 HTTPS 时，PUBLIC_API_BASE 若误写为 http:// 会导致 Mixed Content；构建时把公网 API 规范为 https */
const rawBase = import.meta.env.PUBLIC_API_BASE ?? 'http://localhost:4000';
const apiBase = (() => {
	const s = String(rawBase).trim();
	if (
		s.startsWith('http://') &&
		!s.includes('localhost') &&
		!s.includes('127.0.0.1')
	) {
		return 'https://' + s.slice('http://'.length);
	}
	return s;
})();
---

<!doctype html>
<html lang="zh-CN" data-public-api-base={apiBase}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<meta name="robots" content="noindex,nofollow" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
