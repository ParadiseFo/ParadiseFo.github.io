---
import 'katex/dist/katex.min.css';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	heroImage?: ImageMetadata;
	/** 若设置（如 `/blog/`），在正文上方左侧显示「返回博文列表」 */
	backToBlogHref?: string;
	backToBlogLabel?: string;
}

const { title, description, pubDate, updatedDate, heroImage, backToBlogHref, backToBlogLabel } =
	Astro.props;
const backLabel = backToBlogLabel ?? '返回博文列表';
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.back-to-blog-row {
				width: 100%;
				margin: 0 0 0.75em 0;
				text-align: left;
			}
			.back-to-blog {
				display: inline-flex;
				align-items: center;
				gap: 0.35em;
				font-size: 0.95em;
				color: rgb(var(--gray));
				text-decoration: none;
				border-bottom: 1px solid transparent;
				transition: color 0.15s ease, border-color 0.15s ease;
			}
			.back-to-blog:hover {
				color: var(--accent);
				border-bottom-color: var(--accent);
			}
			/* 宽公式在窄屏上可横向滚动，减轻 CLS 与溢出 */
			:global(.katex-display) {
				overflow-x: auto;
				overflow-y: hidden;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					{
						backToBlogHref && (
							<div class="back-to-blog-row">
								<a class="back-to-blog" href={backToBlogHref}>
									<span aria-hidden="true">←</span> {backLabel}
								</a>
							</div>
						)
					}
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										更新于 <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
