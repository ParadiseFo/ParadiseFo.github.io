---
export const prerender = true;
import type { ImageMetadata } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { fetchPostBySlug, fetchPostList } from '../../lib/api';
import { renderMarkdownToHtml } from '../../lib/renderMarkdown';
import { usePublicApiForPosts } from '../../lib/blog-source';

export async function getStaticPaths() {
	if (usePublicApiForPosts()) {
		try {
			const { data } = await fetchPostList(1, 500);
			return data.map((p) => ({ params: { slug: p.slug } }));
		} catch {
			return [];
		}
	}
	const posts = await getCollection('blog');
	return posts.map((entry) => ({
		params: { slug: entry.id.replace(/\.mdx?$/i, '') },
	}));
}

const slug = Astro.params.slug;
if (!slug) {
	return Astro.redirect('/blog/', 302);
}

const fromApi = usePublicApiForPosts();

let title = '';
let description = '';
let pubDate = new Date();
let updatedDate: Date | undefined;
let heroImage: ImageMetadata | undefined;
let apiHtml: string | null = null;
let LocalContent: (() => unknown) | null = null;

if (fromApi) {
	let post: Awaited<ReturnType<typeof fetchPostBySlug>>;
	try {
		post = await fetchPostBySlug(slug);
	} catch {
		return new Response('文章服务暂时不可用', { status: 502 });
	}
	if (!post) {
		return new Response('未找到文章', { status: 404 });
	}
	title = post.title;
	description = post.summary || post.title;
	pubDate = post.publishedAt ? new Date(post.publishedAt) : new Date(post.updatedAt);
	updatedDate =
		post.updatedAt && post.publishedAt && new Date(post.updatedAt) > new Date(post.publishedAt)
			? new Date(post.updatedAt)
			: undefined;
	try {
		apiHtml = await renderMarkdownToHtml(post.body);
	} catch {
		return new Response('正文渲染失败', { status: 500 });
	}
} else {
	const posts = await getCollection('blog');
	const entry = posts.find((e) => e.id.replace(/\.mdx?$/i, '') === slug);
	if (!entry) {
		return new Response('未找到文章', { status: 404 });
	}
	title = entry.data.title;
	description = entry.data.description;
	pubDate = entry.data.pubDate;
	updatedDate = entry.data.updatedDate;
	heroImage = entry.data.heroImage;
	const rendered = await render(entry);
	LocalContent = rendered.Content;
}
---

<BlogPost
	title={title}
	description={description}
	pubDate={pubDate}
	updatedDate={updatedDate}
	heroImage={heroImage}
	backToBlogHref="/blog/"
>
	<div class="markdown-body">
		{fromApi && apiHtml ? <div set:html={apiHtml} /> : null}
		{!fromApi && LocalContent ? <LocalContent /> : null}
	</div>
</BlogPost>

<style is:global>
	.markdown-body :global(pre) {
		overflow-x: auto;
		padding: 1rem;
		border-radius: 8px;
	}
	.markdown-body :global(code) {
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New',
			monospace;
	}
</style>
